  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "body-parser": "^1.20.4",
    "buffer": "^5.7.1",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "express-ws": "^4.0.0",
    "pino-http": "^10.5.0",
    "pino": "^9.14.0",
    "superagent": "^10.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express-ws": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/superagent": "^4.1.11",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.11",
    "oxlint": "^1.55.0",

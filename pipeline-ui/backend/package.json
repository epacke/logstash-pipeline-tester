{
  "name": "logstash-pipeline-tester",
  "version": "1.0.0",
  "description": "Testing logstash pipelines",
  "main": "build/index.js",
  "scripts": {
    "start": "node ./build/index.js",
    "dev": "cross-env NODE_ENV=DEV PIPELINE_DIRECTORY=../../logstash/logstash-config/pipeline nodemon ./src/index.ts",
    "lint": "oxlint --tsconfig tsconfig.json ./src",
    "typecheck": "tsc --noEmit",
